# Copia este archivo como .env y llena los valores reales
# cp .env.example .env

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/maxi_docs

# Servidor
PORT=3001
NODE_ENV=development

# Monday.com
MONDAY_SIGNING_SECRET=tu_signing_secret
# Token de API de Monday para sync de catálogo (obtenlo en monday.com → Perfil → API)
MONDAY_API_TOKEN=eyJhbGciOi...
# Board de Monday que actúa como catálogo de productos
MONDAY_CATALOG_BOARD_ID=
# IDs de columnas en el board del catálogo (ver en Monday → tablero → ... → Columnas)
MONDAY_CATALOG_SKU_COL=text_mm32knkd
MONDAY_CATALOG_PRICE_COL=numeric_mm321j2y

# DocuSeal (firmas electronicas) — obtener en app.docuseal.com
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=tu_api_key_de_docuseal

# ── EMAIL — elige una opción ────────────────────────────────────────────────
# OPCIÓN A: Resend (recomendado para producción, 3000 emails/mes gratis)
# Obtén tu API key en resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxx

# OPCIÓN B: SMTP Gmail (más fácil para desarrollo/pruebas)
# 1. Activa verificación en 2 pasos en tu cuenta Google
# 2. Ve a myaccount.google.com/apppasswords → crea "Contraseña de aplicación"
# 3. Usa esa clave de 16 caracteres en SMTP_PASS (sin espacios)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=abcdabcdabcdabcd

# Nombre que aparece como remitente en los emails
EMAIL_FROM=MaxiDocs MAXIRent <tu@gmail.com>

# Email que recibe notificación cuando alguien abre o firma un documento
NOTIFY_EMAIL=tu@gmail.com

# Webhook saliente — URL que recibe eventos document.sent / document.signed
WEBHOOK_URL=https://hook.make.com/tu-webhook

# Cloudflare R2 (almacenamiento en la nube, opcional en desarrollo)
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret_key
R2_BUCKET_NAME=maxi-docs-pdfs
R2_PUBLIC_URL=https://tu-bucket.r2.dev

# Frontend (para CORS)
FRONTEND_URL=http://localhost:8301,https://veteran-grape-tartness.ngrok-free.dev

# URL pública del servidor — usada en links de firma y URLs de PDFs firmados
# En local: dejar vacío. En producción o ngrok: poner la URL base
# Ejemplo: PUBLIC_URL=https://veteran-grape-tartness.ngrok-free.dev
PUBLIC_URL=

# Stripe (pagos dentro del documento) — obtener en dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Claude AI (resumen de documentos + generación de contenido) — obtener en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# JWT para embedded signing
JWT_SECRET=cambia-esto-a-una-clave-segura-en-produccion

# Posición por defecto de la firma en el PDF (en % del tamaño de página)
SIGNATURE_X=5
SIGNATURE_Y=77
SIGNATURE_W=38
SIGNATURE_H=9
SIGNATURE_PAGE=1
